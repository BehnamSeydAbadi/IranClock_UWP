<Page
    x:Class="IranClock_UWP.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="20">

            <TextBlock Text="Clock Fix Diagnostic"
                       FontSize="28"
                       FontWeight="SemiBold"/>

            <TextBlock Margin="0,0,0,12"
                       Text="Checks whether your Lumia shows the wrong time because of DST or timezone settings."
                       TextWrapping="Wrap"
                       Opacity="0.8"/>

            <Border Background="#FF1E1E1E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Margin="0,0,0,8" Text="Phone Time" FontSize="16" Opacity="0.8"/>
                    <TextBlock Margin="0,0,0,8"
                               x:Name="PhoneTimeTextBlock"
                               Text="--:--"
                               FontSize="36"
                               FontWeight="Bold"/>

                    <TextBlock Margin="0,12,0,0" Text="UTC Time" FontSize="16" Opacity="0.8"/>
                    <TextBlock Margin="0,0,0,8"
                               x:Name="UtcTimeTextBlock"
                               Text="--:--"
                               FontSize="24"/>

                    <TextBlock Margin="0,12,0,0" Text="Time Zone" FontSize="16" Opacity="0.8"/>
                    <TextBlock Margin="0,0,0,8"
                               x:Name="TimeZoneTextBlock"
                               Text="test time zone"
                               FontSize="18"/>

                    <TextBlock Margin="0,12,0,0" Text="No DST Time" FontSize="16" Opacity="0.8"/>
                    <TextBlock Margin="0,0,0,8"
                               x:Name="SuggestedTimeTextBlock"
                               Text="--:--"
                               FontSize="24"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
